{
  "name": "promise-portal",
  "type": "module",
  "version": "2.1.0",
  "description": "use component as a promisd-like function",
  "author": {
    "name": "tjyuanpeng",
    "email": "tjyuanpeng@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/tjyuanpeng/promise-portal",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tjyuanpeng/promise-portal.git"
  },
  "bugs": {
    "url": "https://github.com/tjyuanpeng/promise-portal/issues"
  },
  "keywords": [
    "vue",
    "promise",
    "portal"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch --tsconfig tsconfig.lib.json",
    "build": "tsdown --tsconfig tsconfig.lib.json",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "vue": "3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@testing-library/vue": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "element-plus": "catalog:",
    "happy-dom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "unplugin-auto-import": "catalog:",
    "unplugin-vue-components": "catalog:",
    "vitest": "catalog:"
  }
}
